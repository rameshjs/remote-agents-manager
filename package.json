{
  "name": "remote-agents-manager",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "bun run --cwd apps/api db:generate",
    "db:migrate": "bun run --cwd apps/api db:migrate",
    "db:push": "bun run --cwd apps/api db:push",
    "db:studio": "bun run --cwd apps/api db:studio",
    "create-user": "bun run --cwd apps/api create-user"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
